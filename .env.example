# Option A: Path to service account JSON file (for local dev)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Option B: Raw JSON string of service account key (for Railway / cloud platforms)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Your Google Ads developer token
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# Bearer token for authenticating Claude.ai requests (generate with: openssl rand -hex 32)
MCP_AUTH_TOKEN=your-auth-token

# Optional: Manager account customer ID (for accessing sub-accounts)
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
